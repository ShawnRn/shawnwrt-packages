#!/bin/sh

# ShawnWrt OTA Auto Update Cron Helper
# Runs in background and checks for updates during scheduled time window

CONFIG="shawnwrt_ota"
LOGFILE="/tmp/shawnwrt-ota/auto-update.log"

log() {
	echo "$(date '+%Y-%m-%d %H:%M:%S') $*" >> "$LOGFILE"
}

get_config() {
	config_load "$CONFIG"
	config_get ENABLED auto enabled 0
	config_get START_HOUR auto start_hour 1
	config_get END_HOUR auto end_hour 3
}

run_auto_update() {
	log "Starting automatic update check..."
	
	# Check for updates
	/usr/bin/shawnwrt-ota check > /dev/null 2>&1
	
	# Get status
	STATE=$(/usr/bin/shawnwrt-ota status 2>/dev/null | grep '^STATE=' | cut -d= -f2)
	
	if [ "$STATE" = "update" ]; then
		log "New version available, starting download and install..."
		/usr/bin/shawnwrt-ota all >> "$LOGFILE" 2>&1
		uci set "$CONFIG.auto.last_run=$(date '+%Y-%m-%d %H:%M:%S')"
		uci commit "$CONFIG"
	else
		log "System is up to date."
	fi
}

# Main loop
LAST_RUN_HOUR=-1

while true; do
	get_config
	
	if [ "$ENABLED" = "1" ]; then
		CURRENT_HOUR=$(date +%H)
		
		# Check if we're within the scheduled time window
		if [ "$CURRENT_HOUR" -ge "$START_HOUR" ] && [ "$CURRENT_HOUR" -lt "$END_HOUR" ]; then
			# Only run once per hour
			if [ "$CURRENT_HOUR" -ne "$LAST_RUN_HOUR" ]; then
				log "Current time ($CURRENT_HOUR:00) is within scheduled window ($START_HOUR:00-$END_HOUR:00)"
				run_auto_update
				LAST_RUN_HOUR=$CURRENT_HOUR
			fi
		else
			LAST_RUN_HOUR=-1
		fi
	fi
	
	sleep 60
done
