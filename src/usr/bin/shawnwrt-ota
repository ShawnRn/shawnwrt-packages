#!/bin/sh
# shellcheck shell=ash

set -eu

REPO="${SHAWNWRT_OTA_REPO:-ShawnRn/immortalwrt-mt7981-cudy-tr3000}"
API_BASE="${SHAWNWRT_OTA_API_BASE:-https://api.github.com}"
DOWNLOAD_DIR="${SHAWNWRT_OTA_DOWNLOAD_DIR:-/tmp/shawnwrt-ota}"
KEEP_PACKAGES="${SHAWNWRT_OTA_KEEP_PACKAGES:-1}"
FORCE="${SHAWNWRT_OTA_FORCE:-0}"
STATE_CONFIG="shawnwrt_ota"
CACHE_FILE="$DOWNLOAD_DIR/latest_info.cache"
PROGRESS_FILE="$DOWNLOAD_DIR/job.progress"

usage() {
	cat <<'EOF'
Usage: shawnwrt-ota <command>

Commands:
  check       Fetch latest firmware info in background or foreground
  status      Show installed and latest firmware state (fast, uses cache)
  download    Download and verify the latest matching firmware
  test        Download, verify, and run sysupgrade --test
  install     Download, verify, test, then run sysupgrade preserving config
  all         Sequential download, verify, test, and install
  start <command>
              Run check/download/test/install/all in the background
  job-status  Show background OTA task status, progress, and recent log
  finalize-pending
              Mark a pending install as installed after first boot
  mark-installed [tag]  Record current or given release tag as installed
  board       Print detected ShawnWrt OTA board id
  help        Show this help
EOF
}

die() {
	echo "shawnwrt-ota: $*" >&2
	exit 1
}

need_cmd() {
	command -v "$1" >/dev/null 2>&1 || die "missing command: $1"
}

json_get() {
	jsonfilter -e "$1" 2>/dev/null || true
}

board_name() {
	cat /tmp/sysinfo/board_name 2>/dev/null || ubus call system board 2>/dev/null | json_get '@.board_name'
}

model_name() {
	ubus call system board 2>/dev/null | json_get '@.model'
}

ota_board() {
	local board model
	board="$(board_name)"
	model="$(model_name)"

	case "$board" in
		qihoo,360t7)
			echo "qihoo_360t7"
			;;
		cudy,tr3000-v1)
			case "$model" in
				*"512MB"*|*"512mb"*)
					echo "cudy_tr3000-512mb-v1"
					;;
				*)
					die "refusing TR3000 OTA: this unit is not detected as 512MB ($model)"
					;;
			esac
			;;
		*)
			die "unsupported board: ${board:-unknown}"
			;;
	esac
}

needs_force_upgrade() {
	local board ota
	board="$(board_name)"
	ota="$(ota_board)"

	[ "$FORCE" = "1" ] && return 0

	# The 512MB TR3000 DTS has a corrected sysupgrade board id while the
	# running system may still report the stock compatible string.
	[ "$board" = "cudy,tr3000-v1" ] && [ "$ota" = "cudy_tr3000-512mb-v1" ]
}

update_progress() {
	[ -n "$1" ] || return 0
	printf '%s\n' "$1" >"$PROGRESS_FILE"
}

release_json() {
	need_cmd curl
	curl -fsSL \
		-H "Accept: application/vnd.github+json" \
		-H "User-Agent: shawnwrt-ota" \
		--connect-timeout 15 \
		--max-time 30 \
		"$API_BASE/repos/$REPO/releases/latest"
}

asset_name_for_board() {
	local json board
	json="$1"
	board="$2"
	printf '%s' "$json" | json_get '@.assets[*].name' | grep -F "$board" | grep -F 'sysupgrade.bin' | head -n 1
}

asset_field() {
	local json name field
	json="$1"
	name="$2"
	field="$3"
	printf '%s' "$json" | json_get "@.assets[@.name=\"$name\"].$field" | head -n 1
}

latest_info() {
	local json board tag name url digest size info
	json="$(release_json)" || die "failed to fetch latest release info from GitHub"
	board="$(ota_board)"
	tag="$(printf '%s' "$json" | json_get '@.tag_name')"
	name="$(asset_name_for_board "$json" "$board")"
	[ -n "$name" ] || die "no sysupgrade asset found for board $board in latest release"
	url="$(asset_field "$json" "$name" browser_download_url)"
	digest="$(asset_field "$json" "$name" digest)"
	size="$(asset_field "$json" "$name" size)"

	info="BOARD=$board
TAG=$tag
ASSET=$name
URL=$url
DIGEST=$digest
SIZE=$size
CHECKED_AT=$(date '+%Y-%m-%d %H:%M:%S %z')"

	mkdir -p "$DOWNLOAD_DIR"
	printf '%s\n' "$info" >"$CACHE_FILE"
	printf '%s\n' "$info"
}

latest_info_cached() {
	if [ -f "$CACHE_FILE" ]; then
		cat "$CACHE_FILE"
	else
		return 1
	fi
}

info_value() {
	printf '%s\n' "$1" | sed -n "s/^$2=//p" | head -n 1
}

uci_get() {
	uci -q get "$1" 2>/dev/null || true
}

system_tag() {
	if [ -f /etc/shawnwrt_version ]; then
		tr -d '\n\r ' </etc/shawnwrt_version
	fi
}

openwrt_release() {
	if [ -f /etc/openwrt_release ]; then
		# shellcheck disable=SC1091
		. /etc/openwrt_release
		printf '%s' "${DISTRIB_RELEASE:-}"
	fi
}

record_installed() {
	local info tag asset digest date
	info="${1:-$(latest_info_cached || latest_info)}"
	tag="$(info_value "$info" TAG)"
	asset="$(info_value "$info" ASSET)"
	digest="$(info_value "$info" DIGEST)"
	date="$(date '+%Y-%m-%d %H:%M:%S %z')"

	[ -n "$tag" ] || die "cannot record installed release without tag"

	touch "/etc/config/${STATE_CONFIG}"
	uci -q batch <<EOF
set ${STATE_CONFIG}.state=state
set ${STATE_CONFIG}.state.installed_tag='${tag}'
set ${STATE_CONFIG}.state.installed_asset='${asset}'
set ${STATE_CONFIG}.state.installed_digest='${digest}'
set ${STATE_CONFIG}.state.installed_at='${date}'
delete ${STATE_CONFIG}.state.pending_tag
delete ${STATE_CONFIG}.state.pending_asset
delete ${STATE_CONFIG}.state.pending_digest
delete ${STATE_CONFIG}.state.pending_at
commit ${STATE_CONFIG}
EOF
}

record_pending() {
	local info tag asset digest date
	info="${1:-$(latest_info_cached || latest_info)}"
	tag="$(info_value "$info" TAG)"
	asset="$(info_value "$info" ASSET)"
	digest="$(info_value "$info" DIGEST)"
	date="$(date '+%Y-%m-%d %H:%M:%S %z')"

	[ -n "$tag" ] || die "cannot record pending release without tag"

	touch "/etc/config/${STATE_CONFIG}"
	uci -q batch <<EOF
set ${STATE_CONFIG}.state=state
set ${STATE_CONFIG}.state.pending_tag='${tag}'
set ${STATE_CONFIG}.state.pending_asset='${asset}'
set ${STATE_CONFIG}.state.pending_digest='${digest}'
set ${STATE_CONFIG}.state.pending_at='${date}'
commit ${STATE_CONFIG}
EOF
}

finalize_pending() {
	local tag asset digest pending_at date
	tag="$(uci_get "${STATE_CONFIG}.state.pending_tag")"
	asset="$(uci_get "${STATE_CONFIG}.state.pending_asset")"
	digest="$(uci_get "${STATE_CONFIG}.state.pending_digest")"
	pending_at="$(uci_get "${STATE_CONFIG}.state.pending_at")"
	date="$(date '+%Y-%m-%d %H:%M:%S %z')"

	[ -n "$tag" ] || return 0

	touch "/etc/config/${STATE_CONFIG}"
	uci -q batch <<EOF
set ${STATE_CONFIG}.state=state
set ${STATE_CONFIG}.state.installed_tag='${tag}'
set ${STATE_CONFIG}.state.installed_asset='${asset}'
set ${STATE_CONFIG}.state.installed_digest='${digest}'
set ${STATE_CONFIG}.state.installed_at='${date}'
set ${STATE_CONFIG}.state.installed_from_pending_at='${pending_at}'
delete ${STATE_CONFIG}.state.pending_tag
delete ${STATE_CONFIG}.state.pending_asset
delete ${STATE_CONFIG}.state.pending_digest
delete ${STATE_CONFIG}.state.pending_at
commit ${STATE_CONFIG}
EOF
}

status_info() {
	local info latest_tag system_version openwrt_version recorded_tag installed_tag installed_asset installed_digest installed_at pending_tag pending_asset pending_digest pending_at state version_source checked_at
	
	info="$(latest_info_cached || true)"
	latest_tag="$(info_value "$info" TAG)"
	checked_at="$(info_value "$info" CHECKED_AT)"

	system_version="$(system_tag)"
	openwrt_version="$(openwrt_release)"
	recorded_tag="$(uci_get "${STATE_CONFIG}.state.installed_tag")"
	installed_tag="$system_version"
	version_source="firmware"

	if [ -z "$installed_tag" ]; then
		installed_tag="$recorded_tag"
		version_source="ota-record"
	fi

	[ -n "$installed_tag" ] || version_source="unknown"

	installed_asset="$(uci_get "${STATE_CONFIG}.state.installed_asset")"
	installed_digest="$(uci_get "${STATE_CONFIG}.state.installed_digest")"
	installed_at="$(uci_get "${STATE_CONFIG}.state.installed_at")"
	pending_tag="$(uci_get "${STATE_CONFIG}.state.pending_tag")"
	pending_asset="$(uci_get "${STATE_CONFIG}.state.pending_asset")"
	pending_digest="$(uci_get "${STATE_CONFIG}.state.pending_digest")"
	pending_at="$(uci_get "${STATE_CONFIG}.state.pending_at")"

	if [ -z "$latest_tag" ]; then
		state="need_check"
	elif [ -n "$pending_tag" ] && [ "$pending_tag" = "$latest_tag" ]; then
		state="pending"
	elif [ -n "$system_version" ] && [ "$system_version" = "$latest_tag" ]; then
		state="current"
	elif [ -n "$system_version" ]; then
		state="update"
	else
		state="unknown"
	fi

	cat <<EOF
STATE=$state
INSTALLED_TAG=$installed_tag
SYSTEM_TAG=$system_version
OPENWRT_RELEASE=$openwrt_version
RECORDED_TAG=$recorded_tag
VERSION_SOURCE=$version_source
CLOUD_TAG=$latest_tag
CHECKED_AT=$checked_at
INSTALLED_ASSET=$installed_asset
INSTALLED_DIGEST=$installed_digest
INSTALLED_AT=$installed_at
PENDING_TAG=$pending_tag
PENDING_ASSET=$pending_asset
PENDING_DIGEST=$pending_digest
PENDING_AT=$pending_at
$info
EOF
}

download_firmware() {
	local info url name digest want got out tmp
	info="$(latest_info_cached || latest_info)"
	url="$(info_value "$info" URL)"
	name="$(info_value "$info" ASSET)"
	digest="$(info_value "$info" DIGEST)"
	out="$DOWNLOAD_DIR/$name"
	tmp="$out.tmp"

	mkdir -p "$DOWNLOAD_DIR"
	update_progress "0"
	echo "$info"
	echo "DOWNLOAD=$out"

	if [ ! -s "$out" ]; then
		rm -f "$tmp"
		# Try to use stdbuf to ensure line buffering for progress parsing
		curl -fsSLo "$tmp" \
			--retry 3 \
			--retry-all-errors \
			--retry-delay 2 \
			--connect-timeout 20 \
			--max-time 900 \
			--progress-bar \
			"$url" 2>&1 | stdbuf -oL tr '\r' '\n' | stdbuf -oL sed -u 's/.* \([0-9.]*\)%/\1/' | while read -r p; do
				case "$p" in
					[0-9]*) update_progress "$p" ;;
				esac
			done || {
				rm -f "$tmp"
				die "download failed: $url"
			}
		mv "$tmp" "$out"
	fi
	update_progress "100"

	case "$digest" in
		sha256:*)
			want="${digest#sha256:}"
			got="$(sha256sum "$out" | awk '{print $1}')"
			if [ "$got" != "$want" ]; then
				rm -f "$out"
				die "sha256 mismatch: got $got expected $want"
			fi
			echo "SHA256=$got"
			;;
		*)
			die "release asset has no sha256 digest"
			;;
	esac

	printf '%s\n' "$out"
}

firmware_path_from_download_output() {
	tail -n 1
}

test_firmware() {
	local out args forced tmp rc download_log
	download_log="$(mktemp)"
	if ! download_firmware >"$download_log"; then
		rc="$?"
		cat "$download_log"
		rm -f "$download_log"
		return "$rc"
	fi
	cat "$download_log"
	out="$(firmware_path_from_download_output <"$download_log")"
	rm -f "$download_log"
	args=""
	forced=0
	if needs_force_upgrade; then
		args="$args -F"
		forced=1
	fi

	tmp="$(mktemp)"
	if sysupgrade -T $args "$out" >"$tmp" 2>&1; then
		if [ "$forced" = "1" ]; then
			echo "INFO_FORCE_TR3000=1"
		else
			cat "$tmp"
		fi
		rm -f "$tmp"
	else
		rc="$?"
		cat "$tmp"
		rm -f "$tmp"
		return "$rc"
	fi
	echo "TEST=ok"
	printf '%s\n' "$out"
}

install_firmware() {
	local out args info log cmd test_log rc
	test_log="$(mktemp)"
	if ! test_firmware >"$test_log"; then
		rc="$?"
		cat "$test_log"
		rm -f "$test_log"
		return "$rc"
	fi
	cat "$test_log"
	out="$(firmware_path_from_download_output <"$test_log")"
	rm -f "$test_log"
	info="$(latest_info_cached || latest_info)"
	args=""
	[ "$KEEP_PACKAGES" = "1" ] && args="$args -k"
	needs_force_upgrade && args="$args -F"
	record_pending "$info"
	log="$DOWNLOAD_DIR/install.log"
	rm -f "$log"
	echo "INSTALL=started"
	echo "DOWNLOAD=$out"
	echo "LOG=$log"
	cmd="sleep 2; exec sysupgrade $args '$out'"
	if command -v setsid >/dev/null 2>&1; then
		setsid sh -c "$cmd" >"$log" 2>&1 </dev/null &
	else
		( sleep 2; exec sysupgrade $args "$out" ) >"$log" 2>&1 </dev/null &
	fi
	echo "PID=$!"
}

all_in_one() {
	echo "ACTION=all_started"
	download_firmware >/dev/null
	echo "ACTION=download_ok"
	test_firmware >/dev/null
	echo "ACTION=test_ok"
	install_firmware
}

job_pid_file() {
	printf '%s\n' "$DOWNLOAD_DIR/job.pid"
}

job_rc_file() {
	printf '%s\n' "$DOWNLOAD_DIR/job.rc"
}

job_log_file() {
	printf '%s\n' "$DOWNLOAD_DIR/job.log"
}

job_cmd_file() {
	printf '%s\n' "$DOWNLOAD_DIR/job.cmd"
}

job_started_file() {
	printf '%s\n' "$DOWNLOAD_DIR/job.started"
}

job_is_running() {
	local pid rcfile
	pid="$1"
	rcfile="$(job_rc_file)"
	[ -n "$pid" ] && kill -0 "$pid" 2>/dev/null && [ ! -f "$rcfile" ]
}

start_job() {
	local cmd pid pidfile rcfile logfile cmdfile startedfile
	cmd="${1:-}"

	case "$cmd" in
		check|download|test|install|all) ;;
		*) die "background command must be one of: check, download, test, install, all" ;;
	esac

	mkdir -p "$DOWNLOAD_DIR"
	pidfile="$(job_pid_file)"
	rcfile="$(job_rc_file)"
	logfile="$(job_log_file)"
	cmdfile="$(job_cmd_file)"
	startedfile="$(job_started_file)"

	pid="$(cat "$pidfile" 2>/dev/null || true)"
	if job_is_running "$pid"; then
		echo "JOB=running"
		echo "JOB_COMMAND=$(cat "$cmdfile" 2>/dev/null || true)"
		echo "JOB_PID=$pid"
		echo "JOB_LOG=$logfile"
		return 0
	fi

	rm -f "$rcfile" "$logfile" "$PROGRESS_FILE"
	printf '%s\n' "$cmd" >"$cmdfile"
	date '+%Y-%m-%d %H:%M:%S %z' >"$startedfile"

	(
		rc=0
		echo "JOB_COMMAND=$cmd"
		echo "JOB_STARTED_AT=$(cat "$startedfile" 2>/dev/null || true)"
		case "$cmd" in
			all) all_in_one ;;
			*) "$0" "$cmd" ;;
		esac
		exit_code=$?
		echo "JOB_EXIT=$exit_code"
		printf '%s\n' "$exit_code" >"$rcfile"
		exit "$exit_code"
	) >"$logfile" 2>&1 &

	pid="$!"
	printf '%s\n' "$pid" >"$pidfile"
	echo "JOB=started"
	echo "JOB_COMMAND=$cmd"
	echo "JOB_PID=$pid"
	echo "JOB_LOG=$logfile"
}

job_status() {
	local pid pidfile rcfile logfile cmdfile startedfile running rc progress
	pidfile="$(job_pid_file)"
	rcfile="$(job_rc_file)"
	logfile="$(job_log_file)"
	cmdfile="$(job_cmd_file)"
	startedfile="$(job_started_file)"
	pid="$(cat "$pidfile" 2>/dev/null || true)"
	running=0
	rc=""
	progress="$(cat "$PROGRESS_FILE" 2>/dev/null || echo "0")"

	if job_is_running "$pid"; then
		running=1
	elif [ -f "$rcfile" ]; then
		rc="$(cat "$rcfile" 2>/dev/null || true)"
	fi

	echo "JOB_RUNNING=$running"
	echo "JOB_COMMAND=$(cat "$cmdfile" 2>/dev/null || true)"
	echo "JOB_PID=$pid"
	echo "JOB_PROGRESS=$progress"
	echo "JOB_STARTED_AT=$(cat "$startedfile" 2>/dev/null || true)"
	echo "JOB_EXIT=$rc"
	echo "JOB_LOG=$logfile"

	if [ -f "$logfile" ]; then
		echo "LOG_BEGIN"
		tail -n 120 "$logfile"
		echo "LOG_END"
	fi
}

main() {
	case "${1:-help}" in
		board)
			ota_board
			;;
		check)
			latest_info
			;;
		status)
			status_info
			;;
		download)
			download_firmware
			;;
		test)
			test_firmware
			;;
		install)
			install_firmware
			;;
		all)
			all_in_one
			;;
		start)
			start_job "${2:-}"
			;;
		job-status)
			job_status
			;;
		finalize-pending)
			finalize_pending
			;;
		mark-installed)
			if [ -n "${2:-}" ]; then
				info="$(latest_info)"
				latest_tag="$(info_value "$info" TAG)"
				[ "$2" = "$latest_tag" ] || die "tag $2 is not the current latest release ($latest_tag)"
				record_installed "$info"
			else
				record_installed "$(latest_info)"
			fi
			status_info
			;;
		help|-h|--help)
			usage
			;;
		*)
			usage >&2
			exit 2
			;;
	esac
}

main "$@"
