#!/bin/sh
# shellcheck shell=ash

set -eu

REPO="${SHAWNWRT_OTA_REPO:-ShawnRn/immortalwrt-mt7981-cudy-tr3000}"
API_BASE="${SHAWNWRT_OTA_API_BASE:-https://api.github.com}"
DOWNLOAD_DIR="${SHAWNWRT_OTA_DOWNLOAD_DIR:-/tmp/shawnwrt-ota}"
KEEP_PACKAGES="${SHAWNWRT_OTA_KEEP_PACKAGES:-1}"
FORCE="${SHAWNWRT_OTA_FORCE:-0}"
STATE_CONFIG="shawnwrt_ota"

usage() {
	cat <<'EOF'
Usage: shawnwrt-ota <command>

Commands:
  check       Show latest matching firmware without downloading
  status      Show installed and latest firmware state
  download    Download and verify the latest matching firmware
  test        Download, verify, and run sysupgrade --test
  install     Download, verify, test, then run sysupgrade preserving config
  mark-installed [tag]  Record current or given release tag as installed
  board       Print detected ShawnWrt OTA board id
  help        Show this help

Environment:
  SHAWNWRT_OTA_REPO=owner/repo
  SHAWNWRT_OTA_DOWNLOAD_DIR=/tmp/shawnwrt-ota
  SHAWNWRT_OTA_FORCE=1
EOF
}

die() {
	echo "shawnwrt-ota: $*" >&2
	exit 1
}

need_cmd() {
	command -v "$1" >/dev/null 2>&1 || die "missing command: $1"
}

json_get() {
	jsonfilter -e "$1" 2>/dev/null || true
}

board_name() {
	cat /tmp/sysinfo/board_name 2>/dev/null || ubus call system board 2>/dev/null | json_get '@.board_name'
}

model_name() {
	ubus call system board 2>/dev/null | json_get '@.model'
}

ota_board() {
	local board model
	board="$(board_name)"
	model="$(model_name)"

	case "$board" in
		qihoo,360t7)
			echo "qihoo_360t7"
			;;
		cudy,tr3000-v1)
			case "$model" in
				*"512MB"*|*"512mb"*)
					echo "cudy_tr3000-512mb-v1"
					;;
				*)
					die "refusing TR3000 OTA: this unit is not detected as 512MB ($model)"
					;;
			esac
			;;
		*)
			die "unsupported board: ${board:-unknown}"
			;;
	esac
}

needs_force_upgrade() {
	local board ota
	board="$(board_name)"
	ota="$(ota_board)"

	[ "$FORCE" = "1" ] && return 0

	# The 512MB TR3000 DTS has a corrected sysupgrade board id while the
	# running system may still report the stock compatible string.
	[ "$board" = "cudy,tr3000-v1" ] && [ "$ota" = "cudy_tr3000-512mb-v1" ]
}

release_json() {
	need_cmd curl
	curl -fsSL \
		-H "Accept: application/vnd.github+json" \
		-H "User-Agent: shawnwrt-ota" \
		"$API_BASE/repos/$REPO/releases/latest"
}

asset_name_for_board() {
	local json board
	json="$1"
	board="$2"
	printf '%s' "$json" | json_get '@.assets[*].name' | grep -F "$board" | grep -F 'sysupgrade.bin' | head -n 1
}

asset_field() {
	local json name field
	json="$1"
	name="$2"
	field="$3"
	printf '%s' "$json" | json_get "@.assets[@.name=\"$name\"].$field" | head -n 1
}

latest_info() {
	local json board tag name url digest size
	json="$(release_json)"
	board="$(ota_board)"
	tag="$(printf '%s' "$json" | json_get '@.tag_name')"
	name="$(asset_name_for_board "$json" "$board")"
	[ -n "$name" ] || die "no sysupgrade asset found for board $board in latest release"
	url="$(asset_field "$json" "$name" browser_download_url)"
	digest="$(asset_field "$json" "$name" digest)"
	size="$(asset_field "$json" "$name" size)"

	cat <<EOF
BOARD=$board
TAG=$tag
ASSET=$name
URL=$url
DIGEST=$digest
SIZE=$size
EOF
}

info_value() {
	printf '%s\n' "$1" | sed -n "s/^$2=//p" | head -n 1
}

uci_get() {
	uci -q get "$1" 2>/dev/null || true
}

record_installed() {
	local info tag asset digest date
	info="${1:-$(latest_info)}"
	tag="$(info_value "$info" TAG)"
	asset="$(info_value "$info" ASSET)"
	digest="$(info_value "$info" DIGEST)"
	date="$(date '+%Y-%m-%d %H:%M:%S %z')"

	[ -n "$tag" ] || die "cannot record installed release without tag"

	touch "/etc/config/${STATE_CONFIG}"
	uci -q batch <<EOF
set ${STATE_CONFIG}.state=state
set ${STATE_CONFIG}.state.installed_tag='${tag}'
set ${STATE_CONFIG}.state.installed_asset='${asset}'
set ${STATE_CONFIG}.state.installed_digest='${digest}'
set ${STATE_CONFIG}.state.installed_at='${date}'
commit ${STATE_CONFIG}
EOF
}

status_info() {
	local info latest_tag installed_tag installed_asset installed_digest installed_at state
	info="$(latest_info)"
	latest_tag="$(info_value "$info" TAG)"
	installed_tag="$(uci_get "${STATE_CONFIG}.state.installed_tag")"
	installed_asset="$(uci_get "${STATE_CONFIG}.state.installed_asset")"
	installed_digest="$(uci_get "${STATE_CONFIG}.state.installed_digest")"
	installed_at="$(uci_get "${STATE_CONFIG}.state.installed_at")"

	if [ -z "$installed_tag" ]; then
		state="unknown"
	elif [ "$installed_tag" = "$latest_tag" ]; then
		state="current"
	else
		state="update"
	fi

	cat <<EOF
STATE=$state
INSTALLED_TAG=$installed_tag
INSTALLED_ASSET=$installed_asset
INSTALLED_DIGEST=$installed_digest
INSTALLED_AT=$installed_at
$info
EOF
}

download_firmware() {
	local info url name digest want got out
	info="$(latest_info)"
	url="$(info_value "$info" URL)"
	name="$(info_value "$info" ASSET)"
	digest="$(info_value "$info" DIGEST)"
	out="$DOWNLOAD_DIR/$name"

	mkdir -p "$DOWNLOAD_DIR"
	echo "$info"
	echo "DOWNLOAD=$out"

	if [ ! -s "$out" ]; then
		curl -fsSL --retry 3 --retry-delay 2 -o "$out.tmp" "$url"
		mv "$out.tmp" "$out"
	fi

	case "$digest" in
		sha256:*)
			want="${digest#sha256:}"
			got="$(sha256sum "$out" | awk '{print $1}')"
			[ "$got" = "$want" ] || die "sha256 mismatch: got $got expected $want"
			echo "SHA256=$got"
			;;
		*)
			die "release asset has no sha256 digest"
			;;
	esac

	printf '%s\n' "$out"
}

firmware_path_from_download_output() {
	tail -n 1
}

test_firmware() {
	local out args
	out="$(download_firmware | firmware_path_from_download_output)"
	args=""
	needs_force_upgrade && args="$args -F"
	# shellcheck disable=SC2086
	sysupgrade -T $args "$out"
	echo "TEST=ok"
	printf '%s\n' "$out"
}

install_firmware() {
	local out args info
	out="$(test_firmware | firmware_path_from_download_output)"
	info="$(latest_info)"
	args=""
	[ "$KEEP_PACKAGES" = "1" ] && args="$args -k"
	needs_force_upgrade && args="$args -F"
	record_installed "$info"
	echo "Installing $out"
	# shellcheck disable=SC2086
	exec sysupgrade $args "$out"
}

main() {
	case "${1:-help}" in
		board)
			ota_board
			;;
		check)
			latest_info
			;;
		status)
			status_info
			;;
		download)
			download_firmware
			;;
		test)
			test_firmware
			;;
		install)
			install_firmware
			;;
		mark-installed)
			if [ -n "${2:-}" ]; then
				info="$(latest_info)"
				latest_tag="$(info_value "$info" TAG)"
				[ "$2" = "$latest_tag" ] || die "tag $2 is not the current latest release ($latest_tag)"
				record_installed "$info"
			else
				record_installed "$(latest_info)"
			fi
			status_info
			;;
		help|-h|--help)
			usage
			;;
		*)
			usage >&2
			exit 2
			;;
	esac
}

main "$@"
